\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/7/7d/MG_Gundam_Ver.2.0_-Solid_Clear_Standard-.jpg/revision/latest?cb=20200924073350\" class=\"mw-file-description image\"><img alt=\"MG Gundam Ver.2.0 -Solid Clear Standard-\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"155\" class=\"mw-file-element lazyload\" data-image-name=\"MG Gundam Ver.2.0 -Solid Clear Standard-.jpg\" data-image-key=\"MG_Gundam_Ver.2.0_-Solid_Clear_Standard-.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/7/7d/MG_Gundam_Ver.2.0_-Solid_Clear_Standard-.jpg/revision/latest/scale-to-width-down/100?cb=20200924073350\" /></a><figcaption></figcaption></figure>\n</td>\n<td>Prize B <a href=\"/wiki/RX-78-2_Gundam\" title=\"RX-78-2 Gundam\">RX-78-2 Gundam Ver.2.0</a> Solid Clear Standard\n</td>\n<td><i><a href=\"/wiki/Mobile_Suit_Gundam\" title=\"Mobile Suit Gundam\">Mobile Suit Gundam</a></i>\n</td>\n<td>N/A\n</td>\n<td>2020 September\n</td>\n<td>Banpresto exclusive re-release of MG-111 with clear color armor parts, offered as a lottery prize.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/d/dd/MG_Gundam_Ver.2.0_-Solid_Clear_Reverse-.jpg/revision/latest?cb=20200924073400\" class=\"mw-file-description image\"><img alt=\"MG Gundam Ver.2.0 -Solid Clear Reverse-\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"155\" class=\"mw-file-element lazyload\" data-image-name=\"MG Gundam Ver.2.0 -Solid Clear Reverse-.jpg\" data-image-key=\"MG_Gundam_Ver.2.0_-Solid_Clear_Reverse-.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/d/dd/MG_Gundam_Ver.2.0_-Solid_Clear_Reverse-.jpg/revision/latest/scale-to-width-down/100?cb=20200924073400\" /></a><figcaption></figcaption></figure>\n</td>\n<td>Prize Last One <a href=\"/wiki/RX-78-2_Gundam\" title=\"RX-78-2 Gundam\">RX-78-2 Gundam Ver.2.0</a> Solid Clear Reverse\n</td>\n<td><i><a href=\"/wiki/Mobile_Suit_Gundam\" title=\"Mobile Suit Gundam\">Mobile Suit Gundam</a></i>\n</td>\n<td>N/A\n</td>\n<td>2020 September\n</td>\n<td>Banpresto exclusive re-release of MG-111 with clear color armor parts, offered as a lottery prize. Clear color armor parts are complementary to that in MG RX-78-2 Gundam Ver.2.0 Solid Clear Standard.<sup id=\"cite_ref-18\" class=\"reference\"><a href=\"#cite_note-18\"><span class=\"cite-bracket\">&#91;</span>18<span class=\"cite-bracket\">&#93;</span></a></sup>\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/8/8f/MG_Expansion_Part_Set_for_Gundam_Barbatos.jpg/revision/latest?cb=20201018122030\" class=\"mw-file-description image\"><img alt=\"MG Expansion Part Set for Gundam Barbatos\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"66\" class=\"mw-file-element lazyload\" data-image-name=\"MG Expansion Part Set for Gundam Barbatos.jpg\" data-image-key=\"MG_Expansion_Part_Set_for_Gundam_Barbatos.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/8/8f/MG_Expansion_Part_Set_for_Gundam_Barbatos.jpg/revision/latest/scale-to-width-down/100?cb=20201018122030\" /></a><figcaption></figcaption></figure>\n</td>\n<td>Expansion Parts Set for <a href=\"/wiki/ASW-G-08_Gundam_Barbatos\" title=\"ASW-G-08 Gundam Barbatos\">Gundam Barbatos</a>\n</td>\n<td><i><a href=\"/wiki/Mobile_Suit_Gundam_IRON-BLOODED_ORPHANS\" title=\"Mobile Suit Gundam IRON-BLOODED ORPHANS\">Mobile Suit Gundam IRON-BLOODED ORPHANS</a></i>\n</td>\n<td>\u00a53,100\n</td>\n<td>2020 October\n</td>\n<td>P-Bandai exclusive accessory kit to convert MG-212 into any of its six other forms. Includes <a href=\"/wiki/TK-53_CGS_Mobile_Worker\" title=\"TK-53 CGS Mobile Worker\">TK-53 CGS Mobile Worker</a> (with parts to create <a href=\"/wiki/TK-53/c_CGS_Mobile_Worker_Commander_Type\" title=\"TK-53/c CGS Mobile Worker Commander Type\">Commander Type</a>), <a href=\"/wiki/Orga_Itsuka\" title=\"Orga Itsuka\">Orga Itsuka</a> figurine and water slide decal sheet.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/f/fe/MG_Gundam_Sandrock_EW_%28Armadillo_Unit%29.jpg/revision/latest?cb=20201018104634\" class=\"mw-file-description image\"><img alt=\"MG Gundam Sandrock EW (Armadillo Unit)\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"81\" class=\"mw-file-element lazyload\" data-image-name=\"MG Gundam Sandrock EW (Armadillo Unit).jpg\" data-image-key=\"MG_Gundam_Sandrock_EW_%28Armadillo_Unit%29.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/f/fe/MG_Gundam_Sandrock_EW_%28Armadillo_Unit%29.jpg/revision/latest/scale-to-width-down/100?cb=20201018104634\" /></a><figcaption></figcaption></figure>\n</td>\n<td><a href=\"/wiki/XXXG-01SR_Gundam_Sandrock_EW\" title=\"XXXG-01SR Gundam Sandrock EW\">XXXG-01SR Gundam Sandrock EW (Armadillo Unit)</a>\n</td>\n<td><i><a href=\"/wiki/New_Mobile_Report_Gundam_Wing_Endless_Waltz:_The_Glory_of_Losers\" class=\"mw-redirect\" title=\"New Mobile Report Gundam Wing Endless Waltz: The Glory of Losers\">New Mobile Report Gundam Wing Endless Waltz: The Glory of Losers</a></i>\n</td>\n<td>\u00a55,800\n</td>\n<td>2020 October\n</td>\n<td>P-Bandai exclusive re-release of MG-149 with Armadillo Unit. Includes water slide decal sheet.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/e/e1/MG_Testament_Gundam.jpg/revision/latest?cb=20201120185602\" class=\"mw-file-description image\"><img alt=\"MG Testament Gundam\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"80\" class=\"mw-file-element lazyload\" data-image-name=\"MG Testament Gundam.jpg\" data-image-key=\"MG_Testament_Gundam.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/e/e1/MG_Testament_Gundam.jpg/revision/latest/scale-to-width-down/100?cb=20201120185602\" /></a><figcaption></figcaption></figure>\n</td>\n<td><a href=\"/wiki/ZGMF-X12A_Testament_Gundam\" title=\"ZGMF-X12A Testament Gundam\">RGX-00 Testament Gundam</a>\n</td>\n<td><i><a href=\"/wiki/Mobile_Suit_Gundam_SEED_Destiny_Astray\" title=\"Mobile Suit Gundam SEED Destiny Astray\">Mobile Suit Gundam SEED Destiny Astray</a></i>\n</td>\n<td>\u00a55,700\n</td>\n<td>2020 November\n</td>\n<td>P-Bandai exclusive release. Includes Trikeros Kai and AQM/E-X05 Divine Striker to create RGX-00+AQM/E-X05 Divine Testament Gundam, dark red BA-13 Action Base 1 and water slide decal sheet. Originally planned to be released in October 2020, but was delayed due to unspecified reasons.<sup id=\"cite_ref-19\" class=\"reference\"><a href=\"#cite_note-19\"><span class=\"cite-bracket\">&#91;</span>19<span class=\"cite-bracket\">&#93;</span></a></sup>\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/4/44/MG_Gundam_Stormbringer_F.A._GM_Turbulence.jpg/revision/latest?cb=20201126083325\" class=\"mw-file-description image\"><img alt=\"MG Gundam Stormbringer F.A. GM Turbulence\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"79\" class=\"mw-file-element lazyload\" data-image-name=\"MG Gundam Stormbringer F.A. GM Turbulence.jpg\" data-image-key=\"MG_Gundam_Stormbringer_F.A._GM_Turbulence.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/4/44/MG_Gundam_Stormbringer_F.A._GM_Turbulence.jpg/revision/latest/scale-to-width-down/100?cb=20201126083325\" /></a><figcaption></figcaption></figure>\n</td>\n<td><a href=\"/wiki/RX-78TB-3%EF%BC%BBFA%EF%BC%BD_Gundam_Stormbringer_F.A.\" title=\"RX-78TB-3\uff3bFA\uff3d Gundam Stormbringer F.A.\">RX-78TB-3[SB] Gundam Stormbringer F.A.</a> / <a href=\"/wiki/RGM-79TB-1%EF%BC%BBT%EF%BC%BD_GM_Turbulence\" title=\"RGM-79TB-1\uff3bT\uff3d GM Turbulence\">RGM-79TB-1[T] GM Turbulence</a>\n</td>\n<td><i><a href=\"/wiki/Gundam_Build_Divers_GBWC\" title=\"Gundam Build Divers GBWC\">Gundam Build Divers GBWC</a></i>\n</td>\n<td>\u00a55,700\n</td>\n<td>2020 November\n</td>\n<td>P-Bandai exclusive parts and color variant of MG <a href=\"/wiki/RX-78TB-2%EF%BC%BBSB%EF%BC%BD_Gundam_Stormbringer\" title=\"RX-78TB-2\uff3bSB\uff3d Gundam Stormbringer\">RX-78TB-2[SB] Gundam Stormbringer</a>. Includes head, shoulder and backpack parts of both units such that one can be built at any time, as well as water slide decal sheet.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/b/b7/MG_RX-78-2_Gundam_%28Perfect_Gundam_Ver.%29_-Anime_Color-.jpg/revision/latest?cb=20201205101323\" class=\"mw-file-description image\"><img alt=\"MG RX-78-2 Gundam (Perfect Gundam Ver.) -Anime Color-\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"155\" class=\"mw-file-element lazyload\" data-image-name=\"MG RX-78-2 Gundam (Perfect Gundam Ver.) -Anime Color-.jpg\" data-image-key=\"MG_RX-78-2_Gundam_%28Perfect_Gundam_Ver.%29_-Anime_Color-.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/b/b7/MG_RX-78-2_Gundam_%28Perfect_Gundam_Ver.%29_-Anime_Color-.jpg/revision/latest/scale-to-width-down/100?cb=20201205101323\" /></a><figcaption></figcaption></figure>\n</td>\n<td>The Gundam Base Limited <a href=\"/wiki/RX-78-2_Gundam\" title=\"RX-78-2 Gundam\">RX-78-2 Gundam</a> (<a href=\"/wiki/PF-78-1_Perfect_Gundam\" title=\"PF-78-1 Perfect Gundam\">Perfect Gundam</a> Ver.) [Anime Color]\n</td>\n<td><i><a href=\"/wiki/Plamo-Kyoshiro\" title=\"Plamo-Kyoshiro\">Plamo-Kyoshiro</a></i>\n</td>\n<td>\u00a53,000\n</td>\n<td>2020 December\n</td>\n<td>The Gundam Base exclusive color variant of RX-78-2 Gundam from MG-067. Includes rescaled decals from <a href=\"/wiki/Perfect_Grade\" title=\"Perfect Grade\">PGU</a>-01.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/6/65/MG_Blaze_ZAKU_Phantom_Blaze_ZAKU_Warrior.jpg/revision/latest?cb=20201221040150\" class=\"mw-file-description image\"><img alt=\"MG Blaze ZAKU Phantom Blaze ZAKU Warrior\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"79\" class=\"mw-file-element lazyload\" data-image-name=\"MG Blaze ZAKU Phantom Blaze ZAKU Warrior.jpg\" data-image-key=\"MG_Blaze_ZAKU_Phantom_Blaze_ZAKU_Warrior.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/6/65/MG_Blaze_ZAKU_Phantom_Blaze_ZAKU_Warrior.jpg/revision/latest/scale-to-width-down/100?cb=20201221040150\" /></a><figcaption></figcaption></figure>\n</td>\n<td><a href=\"/wiki/ZGMF-1001/M_Blaze_ZAKU_Phantom\" title=\"ZGMF-1001/M Blaze ZAKU Phantom\">ZGMF-1001/M Blaze ZAKU Phantom</a> / <a href=\"/wiki/ZGMF-1000/M_Blaze_ZAKU_Warrior\" title=\"ZGMF-1000/M Blaze ZAKU Warrior\">ZGMF-1000/M Blaze ZAKU Warrior</a>\n</td>\n<td><i><a href=\"/wiki/Mobile_Suit_Gundam_SEED_Destiny\" title=\"Mobile Suit Gundam SEED Destiny\">Mobile Suit Gundam SEED Destiny</a></i>\n</td>\n<td>\u00a54,500\n</td>\n<td>2020 December\n</td>\n<td>P-Bandai exclusive parts and color variant of MG-211. Includes head and shoulder parts of both units such that one can be built at any time, as well as water slide decal sheet.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/4/42/MG_Gundam_TR-1_-Hazel_Owsla-.jpg/revision/latest?cb=20210220024215\" class=\"mw-file-description image\"><img alt=\"MG Gundam TR-1 -Hazel Owsla-\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"123\" class=\"mw-file-element lazyload\" data-image-name=\"MG Gundam TR-1 -Hazel Owsla-.jpg\" data-image-key=\"MG_Gundam_TR-1_-Hazel_Owsla-.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/4/42/MG_Gundam_TR-1_-Hazel_Owsla-.jpg/revision/latest/scale-to-width-down/100?cb=20210220024215\" /></a><figcaption></figcaption></figure>\n</td>\n<td><a href=\"/wiki/RX-121-2_Gundam_TR-1_%EF%BC%BBHazel_Owsla%EF%BC%BD\" class=\"mw-redirect\" title=\"RX-121-2 Gundam TR-1 \uff3bHazel Owsla\uff3d\">RX-121-2 Gundam TR-1 [Hazel Owsla]</a>\n</td>\n<td><i><a href=\"/wiki/Advance_of_Zeta:_The_Flag_of_Titans\" title=\"Advance of Zeta: The Flag of Titans\">Advance of Zeta: The Flag of Titans</a></i>\n</td>\n<td>\u00a58,000\n</td>\n<td>2020 December\n</td>\n<td>P-Bandai exclusive parts variant of MG <a href=\"/wiki/RX-121-1_Gundam_TR-1_%EF%BC%BBHazel_Custom%EF%BC%BD\" title=\"RX-121-1 Gundam TR-1 \uff3bHazel Custom\uff3d\">RX-121-1 Gundam TR-1 [Hazel Custom]</a>. Includes water slide decal sheet.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/1/1e/MG_Emergency_Escape_Pod_-Primrose-_Expansion_Set.jpg/revision/latest?cb=20201221040133\" class=\"mw-file-description image\"><img alt=\"MG Emergency Escape Pod -Primrose- Expansion Set\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"81\" class=\"mw-file-element lazyload\" data-image-name=\"MG Emergency Escape Pod -Primrose- Expansion Set.jpg\" data-image-key=\"MG_Emergency_Escape_Pod_-Primrose-_Expansion_Set.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/1/1e/MG_Emergency_Escape_Pod_-Primrose-_Expansion_Set.jpg/revision/latest/scale-to-width-down/100?cb=20201221040133\" /></a><figcaption></figcaption></figure>\n</td>\n<td><a href=\"/wiki/Emergency_Escape_Pod_%EF%BC%BBPrimrose%EF%BC%BD\" title=\"Emergency Escape Pod \uff3bPrimrose\uff3d\">Emergency Escape Pod [Primrose]</a> Expansion Set\n</td>\n<td><i><a href=\"/wiki/Advance_of_Zeta:_The_Flag_of_Titans\" title=\"Advance of Zeta: The Flag of Titans\">Advance of Zeta: The Flag of Titans</a></i>\n</td>\n<td>\u00a52,500\n</td>\n<td>2020 December\n</td>\n<td>P-Bandai exclusive accessory kit to convert MG <a href=\"/wiki/RX-121-1_Gundam_TR-1_%EF%BC%BBHazel_Custom%EF%BC%BD\" title=\"RX-121-1 Gundam TR-1 \uff3bHazel Custom\uff3d\">RX-121-1 Gundam TR-1 [Hazel Custom]</a> into <a href=\"/wiki/RX-121-2_Gundam_TR-1_%EF%BC%BBHazel_Owsla%EF%BC%BD\" class=\"mw-redirect\" title=\"RX-121-2 Gundam TR-1 \uff3bHazel Owsla\uff3d\">RX-121-2 Gundam TR-1 [Hazel Owsla]</a>, together with parts from MG <a href=\"/wiki/RX-121-2A_Gundam_TR-1_%EF%BC%BBAdvanced_Hazel%EF%BC%BD\" title=\"RX-121-2A Gundam TR-1 \uff3bAdvanced Hazel\uff3d\">RX-121-2A Gundam TR-1 [Advanced Hazel]</a>, MG <a href=\"/wiki/RX-121-2_Gundam_TR-1_%EF%BC%BBHazel_II%EF%BC%BD\" title=\"RX-121-2 Gundam TR-1 \uff3bHazel II\uff3d\">RX-121-2 Gundam TR-1 [Hazel II] Early Type</a> / <a href=\"/wiki/RGM-79Q_GM_Quel_%EF%BC%BBHazel_Reserve_Unit%EF%BC%BD\" class=\"mw-redirect\" title=\"RGM-79Q GM Quel \uff3bHazel Reserve Unit\uff3d\">RGM-79Q Hazel Reserve Unit</a> / <a href=\"/wiki/RGM-79Q_GM_Quel\" title=\"RGM-79Q GM Quel\">GM Quel</a> and MG <a href=\"/wiki/FF-X29A_G-Parts_%EF%BC%BBHrududu%EF%BC%BD\" title=\"FF-X29A G-Parts \uff3bHrududu\uff3d\">FF-X29A G-Parts [Hrududu]</a>.<sup id=\"cite_ref-20\" class=\"reference\"><a href=\"#cite_note-20\"><span class=\"cite-bracket\">&#91;</span>20<span class=\"cite-bracket\">&#93;</span></a></sup> Emergency Escape Pod [Primrose] can also be created using backpack parts from MG RX-121-1 Gundam TR-1 [Hazel Custom]. Includes black BA-13 Action Base 1 with additional black Action Base 4 arm and water slide decal sheet.\n</td>\n<td>\n</td></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/c/c4/MG_Mission_Pack_D-Type_%26_G-Type.jpg/revision/latest?cb=20201221141531\" class=\"mw-file-description image\"><img alt=\"MG Mission Pack D-Type &amp; G-Type\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"157\" class=\"mw-file-element lazyload\" data-image-name=\"MG Mission Pack D-Type &amp; G-Type.jpg\" data-image-key=\"MG_Mission_Pack_D-Type_%26_G-Type.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/c/c4/MG_Mission_Pack_D-Type_%26_G-Type.jpg/revision/latest/scale-to-width-down/100?cb=20201221141531\" /></a><figcaption></figcaption></figure>\n</td>\n<td><a href=\"/wiki/Mission_Packs\" title=\"Mission Packs\">Mission Pack</a> <a href=\"/wiki/F90D_Gundam_F90_Destroid_Type\" title=\"F90D Gundam F90 Destroid Type\">D-Type</a> &amp; <a href=\"/wiki/F90G_Gundam_F90_Guards_Type\" title=\"F90G Gundam F90 Guards Type\">G-Type</a> for <a href=\"/wiki/F90_Gundam_F90\" title=\"F90 Gundam F90\">Gundam F90</a>\n</td>\n<td><i><a href=\"/wiki/Mobile_Suit_Gundam_F90\" title=\"Mobile Suit Gundam F90\">Mobile Suit Gundam F90</a></i>\n</td>\n<td>\u00a52,000\n</td>\n<td>2020 December\n</td>\n<td>P-Bandai exclusive accessory kit to convert MG F90 Gundam F90 into F90D Gundam F90 Destroid Type or F90G Gundam F90 Guards Type; also compatible with MG <a href=\"/wiki/F90II_Gundam_F90II\" title=\"F90II Gundam F90II\">F90II Gundam F90II</a>. Includes water slide decal sheet. Released as part of P-Bandai's <a href=\"/wiki/F90_A_to_Z_PROJECT\" title=\"F90 A to Z PROJECT\">F90 A to Z Project</a>.\n</td>\n<td>\n</td></tr></tbody></table><p class=\"mw-empty-elt\"></p></div><div class=\"wds-tab__content\"><p class=\"mw-empty-elt\">\n</p><table class=\"wikitable sortable\">\n<tbody><tr>\n<th>MG #\n</th>\n<th>Model\n</th>\n<th>Series\n</th>\n<th>Yen Price\n</th>\n<th>Release Date\n</th>\n<th>Notes\n</th>\n<th>Link\n</th></tr>\n<tr>\n<td>N/A <figure class=\"mw-halign-right\" typeof=\"mw:File\"><a href=\"https://static.wikia.nocookie.net/gundam/images/9/91/MG_OZ-13MS_Gundam_Epyon_EW_-Special_Coating-.jpg/revision/latest?cb=20201228160938\" class=\"mw-file-description image\"><img alt=\"MG OZ-13MS Gundam Epyon EW -Special Coating-\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"100\" height=\"79\" class=\"mw-file-element lazyload\" data-image-name=\"MG OZ-13MS Gundam Epyon EW -Special Coating-.jpg\" data-image-key=\"MG_OZ-13MS_Gundam_Epyon_EW_-Special_Coating-.jpg\" data-relevant=\"1\" data-src=\"https://static.wikia.nocookie.net/gundam/images/9/91/MG_OZ-13MS_Gundam_Epyon_EW_-Special_Coating-.jpg/revision/latest/scale-to-width-down/100?cb=20201228160938\" /></a><figcaption></figcaption></figure>\n</td>\n<td>The Gundam Base Limited <a href=\"/wiki/OZ-13MS_Gundam_Epyon\" title=\"OZ-13MS Gundam Epyon\">OZ-13MS Gundam Epyon EW</a> [Special Coating]\n</td>\n<td><i><a href=\"/wiki/New_Mobile_Report_Gundam_Wing_Endless_Waltz:_The_Glory_of_Losers\" class=\"mw-redirect\" title=\"New Mobile Report Gundam Wing Endless Waltz: The Glory of Losers\">New Mobile Report