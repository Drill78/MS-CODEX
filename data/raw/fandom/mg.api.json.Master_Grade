{"parse":{"title":"Master Grade","pageid":17795,"text":{"*":"<div class=\"mw-content-ltr mw-parser-output\" lang=\"en\" dir=\"ltr\"><p>\n<aside role=\"region\" class=\"portable-infobox pi-background pi-border-color pi-theme-wikia pi-layout-default\">\n<h2 class=\"pi-item pi-item-spacing pi-title pi-secondary-background\" data-source=\"displaytitle\">Master Grade</h2>\n\n\t<div class=\"pi-image-collection wds-tabber\">\n\t\t<div class=\"wds-tabs__wrapper\">\n\t\t\t<ul class=\"wds-tabs\">\n\t\t\t\t\n\t\t\t\t\t<li class=\"wds-tabs__tab wds-is-current\">\n\t\t\t\t\t\t<span class=\"wds-tabs__tab-label\">\n\t\t\t\t\t\t\tMG\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t</span>\n\t\t\t\t\t</li>\n\t\t\t\t\n\t\t\t\t\t<li class=\"wds-tabs__tab\">\n\t\t\t\t\t\t<span class=\"wds-tabs__tab-label\">\n\t\t\t\t\t\t\tMG \"Ver.Ka\"\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t</span>\n\t\t\t\t\t</li>\n\t\t\t\t\n\t\t\t\t\t<li class=\"wds-tabs__tab\">\n\t\t\t\t\t\t<span class=\"wds-tabs__tab-label\">\n\t\t\t\t\t\t\tMG Extreme\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t</span>\n\t\t\t\t\t</li>\n\t\t\t\t\n\t\t\t\t\t<li class=\"wds-tabs__tab\">\n\t\t\t\t\t\t<span class=\"wds-tabs__tab-label\">\n\t\t\t\t\t\t\tMG Extreme \"Ver.Ka\"\n\t\t\t\t\t\t\t\n\t\t\t\t\t\t</span>\n\t\t\t\t\t</li>\n\t\t\t\t\n\t\t\t</ul>\n\t\t</div>\n\t\t\n\t\t\t<div class=\"wds-tab__content wds-is-current\">\n\t\t\t\t<figure class=\"pi-item pi-image\">\n\t\t\t\t\t<a href=\"https://static.wikia.nocookie.net/gundam/images/3/39/MGlogo.jpg/revision/latest?cb=20150702113607\" class=\"image image-thumbnail\" title=\"MG\">\n\t\t\t\t\t\t<img src=\"https://static.wikia.nocookie.net/gundam/images/3/39/MGlogo.jpg/revision/latest/scale-to-width-down/268?cb=20150702113607\" srcset=\"https://static.wikia.nocookie.net/gundam/images/3/39/MGlogo.jpg/revision/latest/scale-to-width-down/268?cb=20150702113607 1x, https://static.wikia.nocookie.net/gundam/images/3/39/MGlogo.jpg/revision/latest/scale-to-width-down/536?cb=20150702113607 2x\" data-relevant=\"1\" class=\"pi-image-thumbnail\" alt=\"MG\" width=\"270\" height=\"146\" data-image-key=\"MGlogo.jpg\" data-image-name=\"MGlogo.jpg\" />\n\t\t\t\t\t\t\n\t\t\t\t\t</a>\n\t\t\t\t</figure>\n\t\t\t</div>\n\t\t\n\t\t\t<div class=\"wds-tab__content\">\n\t\t\t\t<figure class=\"pi-item pi-image\">\n\t\t\t\t\t<a href=\"https://static.wikia.nocookie.net/gundam/images/6/64/MG_Ver_Ka_Logo.png/revision/latest?cb=20200611091959\" class=\"image image-thumbnail\" title=\"MG &quot;Ver.Ka&quot;\">\n\t\t\t\t\t\t<img src=\"https://static.wikia.nocookie.net/gundam/images/6/64/MG_Ver_Ka_Logo.png/revision/latest/scale-to-width-down/268?cb=20200611091959\" srcset=\"https://static.wikia.nocookie.net/gundam/images/6/64/MG_Ver_Ka_Logo.png/revision/latest/scale-to-width-down/268?cb=20200611091959 1x, https://static.wikia.nocookie.net/gundam/images/6/64/MG_Ver_Ka_Logo.png/revision/latest?cb=20200611091959 2x\" data-relevant=\"1\" class=\"pi-image-thumbnail\" alt=\"MG &quot;Ver.Ka&quot;\" width=\"270\" height=\"183\" data-image-key=\"MG Ver Ka Logo.png\" data-image-name=\"MG Ver Ka Logo.png\" />\n\t\t\t\t\t\t\n\t\t\t\t\t</a>\n\t\t\t\t</figure>\n\t\t\t</div>\n\t\t\n\t\t\t<div class=\"wds-tab__content\">\n\t\t\t\t<figure class=\"pi-item pi-image\">\n\t\t\t\t\t<a href=\"https://static.wikia.nocookie.net/gundam/images/3/37/MG_Extreme_Logo.png/revision/latest?cb=20201113000512\" class=\"image image-thumbnail\" title=\"MG Extreme\">\n\t\t\t\t\t\t<img src=\"https://static.wikia.nocookie.net/gundam/images/3/37/MG_Extreme_Logo.png/revision/latest/scale-to-width-down/267?cb=20201113000512\" srcset=\"https://static.wikia.nocookie.net/gundam/images/3/37/MG_Extreme_Logo.png/revision/latest/scale-to-width-down/267?cb=20201113000512 1x, https://static.wikia.nocookie.net/gundam/images/3/37/MG_Extreme_Logo.png/revision/latest?cb=20201113000512 2x\" data-relevant=\"1\" class=\"pi-image-thumbnail\" alt=\"MG Extreme\" width=\"270\" height=\"91\" data-image-key=\"MG Extreme Logo.png\" data-image-name=\"MG Extreme Logo.png\" />\n\t\t\t\t\t\t\n\t\t\t\t\t</a>\n\t\t\t\t</figure>\n\t\t\t</div>\n\t\t\n\t\t\t<div class=\"wds-tab__content\">\n\t\t\t\t<figure class=\"pi-item pi-image\">\n\t\t\t\t\t<a href=\"https://static.wikia.nocookie.net/gundam/images/8/8b/MGEX_Ver_Ka_Logo.png/revision/latest?cb=20200702012555\" class=\"image image-thumbnail\" title=\"MG Extreme &quot;Ver.Ka&quot;\">\n\t\t\t\t\t\t<img src=\"https://static.wikia.nocookie.net/gundam/images/8/8b/MGEX_Ver_Ka_Logo.png/revision/latest/scale-to-width-down/267?cb=20200702012555\" srcset=\"https://static.wikia.nocookie.net/gundam/images/8/8b/MGEX_Ver_Ka_Logo.png/revision/latest/scale-to-width-down/267?cb=20200702012555 1x, https://static.wikia.nocookie.net/gundam/images/8/8b/MGEX_Ver_Ka_Logo.png/revision/latest?cb=20200702012555 2x\" data-relevant=\"1\" class=\"pi-image-thumbnail\" alt=\"MG Extreme &quot;Ver.Ka&quot;\" width=\"270\" height=\"120\" data-image-key=\"MGEX Ver Ka Logo.png\" data-image-name=\"MGEX Ver Ka Logo.png\" />\n\t\t\t\t\t\t\n\t\t\t\t\t</a>\n\t\t\t\t</figure>\n\t\t\t</div>\n\t\t\n\t</div>\n\n\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"type\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Merchandise Type</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><ul><li>Model Kit <span class=\"plainlinks\" title=\"Search the other 8 pages containing the property &quot;Merchandise Type&quot; with the value &quot;Model Kit&quot;\"><span class=\"mw-default-size\" typeof=\"mw:File\"><a href=\"https://gundam.fandom.com/wiki/Special:SearchByProperty?property=Merchandise_Type&amp;value=Model+Kit\" target=\"_blank\" rel=\"noreferrer noopener\"><img alt=\"Icon - Search\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"12\" height=\"12\" class=\"mw-file-element lazyload\" data-image-name=\"Icon - Search.png\" data-image-key=\"Icon_-_Search.png\" data-relevant=\"0\" data-src=\"https://static.wikia.nocookie.net/gundam/images/e/ef/Icon_-_Search.png/revision/latest?cb=20120427204701\" /></a></span></span></li><li>Gunpla <span class=\"plainlinks\" title=\"Search the other 8 pages containing the property &quot;Merchandise Type&quot; with the value &quot;Gunpla&quot;\"><span class=\"mw-default-size\" typeof=\"mw:File\"><a href=\"https://gundam.fandom.com/wiki/Special:SearchByProperty?property=Merchandise_Type&amp;value=Gunpla\" target=\"_blank\" rel=\"noreferrer noopener\"><img alt=\"Icon - Search\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"12\" height=\"12\" class=\"mw-file-element lazyload\" data-image-name=\"Icon - Search.png\" data-image-key=\"Icon_-_Search.png\" data-relevant=\"0\" data-src=\"https://static.wikia.nocookie.net/gundam/images/e/ef/Icon_-_Search.png/revision/latest?cb=20120427204701\" /></a></span></span></li></ul></div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"manufacturer\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Manufacturer</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><ul><li><a href=\"https://en.wikipedia.org/wiki/Bandai\" class=\"extiw\" title=\"wikipedia:Bandai\">Bandai</a> <span class=\"plainlinks\" title=\"Search the other 8 pages containing the property &quot;Merchandise Manufacturer&quot; with the value &quot;Bandai&quot;\"><span class=\"mw-default-size\" typeof=\"mw:File\"><a href=\"https://gundam.fandom.com/wiki/Special:SearchByProperty?property=Merchandise_Manufacturer&amp;value=Bandai\" target=\"_blank\" rel=\"noreferrer noopener\"><img alt=\"Icon - Search\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"12\" height=\"12\" class=\"mw-file-element lazyload\" data-image-name=\"Icon - Search.png\" data-image-key=\"Icon_-_Search.png\" data-relevant=\"0\" data-src=\"https://static.wikia.nocookie.net/gundam/images/e/ef/Icon_-_Search.png/revision/latest?cb=20120427204701\" /></a></span></span></li></ul></div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"grade\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Grade</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><ul><li>Master Grade</li></ul></div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"scale\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Scale</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><ul><li>1/100</li></ul></div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"era\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Era</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><ul><li><a href=\"/wiki/Universal_Century\" title=\"Universal Century\">Universal Century</a> <span class=\"plainlinks\" title=\"Search the other 3822 pages containing the property &quot;Era&quot; with the value &quot;Universal Century&quot;\"><span class=\"mw-default-size\" typeof=\"mw:File\"><a href=\"https://gundam.fandom.com/wiki/Special:SearchByProperty?property=Era&amp;value=Universal+Century\" target=\"_blank\" rel=\"noreferrer noopener\"><img alt=\"Icon - Search\" src=\"data:image/gif;base64,R0lGODlhAQABAIABAAAAAP///yH5BAEAAAEALAAAAAABAAEAQAICTAEAOw%3D%3D\" decoding=\"async\" loading=\"lazy\" width=\"12\" height=\"12\" class=\"mw-file-element lazyload\" data-image-name=\"Icon - Search.png\" data-image-key=\"Icon_-_Search.png\" data-relevant=\"0\" data-src=\"https://static.wikia.nocookie.net/gundam/images/e/ef/Icon_-_Search.png/revision/latest?cb=20120427204701\" /></a></span></span></li><li><a href=\"/wiki/Future_Century\" title=\"Future Century\">Future Century</a> <span class=\"plainlinks\" title=\"Search the other 225 pages containing the property &quot;Era&quot; with the value &quot;Future Century&quot;\"><span class=\"mw-default-size\" typeof=\"mw:File\"><a href=\"https://gundam.fandom.c